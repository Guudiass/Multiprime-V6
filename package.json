{
  "name": "multiprime-v6",
  "version": "6.0.1",
  "description": "MultiPrime V6 - Navegador Seguro",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "publish": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.designerprime.multiprime",
    "productName": "MultiPrime V6",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-secure.js",
      "preload-toolbar.js",
      "toolbar.html",
      "icon.*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "allowElevation": true
    },
    "publish": {
      "provider": "github",
      "owner": "Guudiass",
      "repo": "Multiprime-V6"
    },
    "asar": true
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
